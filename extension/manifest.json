{
  "manifest_version": 3,
  "name": "Beacon",
  "version": "0.1.0",
  "description": "A privacy-first scam detection tool that helps identify phishing and fraudulent content.",

  "action": {
    "default_popup": "dist/popup/popup.html",
    "default_title": "Beacon - Scam Detector"
  },

  "permissions": [
    "activeTab"
  ],

  "background": {
    "service_worker": "dist/background/background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/content.js"]
    }
  ]
}