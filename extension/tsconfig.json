{
  "compilerOptions": {
    "target": "ES6",
    "module": "none",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "noEmit": false,
    "sourceMap": false,
    "types": ["chrome"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}