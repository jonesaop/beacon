{
  "compilerOptions": {
    "target": "ES6",
    "module": "ES2015",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "src",
    "types": ["chrome"],
    "lib": ["DOM", "ES2020"],
    "strict": true,
    "noEmit": false,
    "sourceMap": false,
    "types": ["chrome"],
    "skipLibCheck": true,
    "importsNotUsedAsValues": "remove"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}